<Window x:Class="AlarmWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AlarmWPF"
        mc:Ignorable="d"
        Title="Alarme" Height="400" Width="600" Loaded="Window_Loaded" LayoutUpdated="Window_LayoutUpdated">
    <Grid>
        <Canvas x:Name="CNVClock" Width="300" Height="300" Margin="282,42,18,42"/>
        <ListBox x:Name="LBSDateTime" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="19,55,353,130"/>
        <Button x:Name="BTNAjouter" Content="Ajouter" HorizontalAlignment="Left" Margin="45,327,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.308,-0.153" Click="BTNAjouter_Click"/>
        <Button x:Name="BTNSupprimer" Content="Supprimer" HorizontalAlignment="Left" Margin="120,327,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.308,-0.153" Click="BTNSupprimer_Click"/>
        <Label Content=":" HorizontalAlignment="Left" Margin="106,277,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="TBXHeurs" HorizontalAlignment="Left" Margin="72,282,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="32" Height="21"/>
        <TextBox x:Name="TBXMinutes" HorizontalAlignment="Left" Margin="120,282,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="32" Height="21"/>
    </Grid>
</Window>
