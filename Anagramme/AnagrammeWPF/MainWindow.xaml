<Window x:Class="AnagrammeWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AnagrammeWPF"
        mc:Ignorable="d"
        Title="Anagramme" Height="488" Width="634" Loaded="Window_Loaded">
    <Grid>
        <Label x:Name="LBLTextMot" Content="Mot à devenir" HorizontalAlignment="Left" Margin="42,12,0,0" VerticalAlignment="Top" Width="118" RenderTransformOrigin="0.316,0.358"/>
        <Label x:Name="LBLMot" Content="MOT" HorizontalAlignment="Left" Margin="42,25,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.013,-0.865" Width="195" FontWeight="Bold" FontSize="22"/>
        <GroupBox Header="Proposition" Margin="11,57,347,295">
            <Grid x:Name="GBXProposition" Height="63" Margin="0,0,-2,0">
                <TextBox x:Name="TBXProposition" HorizontalAlignment="Left" Margin="10,14,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="152" RenderTransformOrigin="0.094,0.756"/>
                <Button x:Name="BTNTester" Content="Tester" HorizontalAlignment="Left" Margin="182,8,0,0" VerticalAlignment="Top" Width="52" Click="BTNTester_Click"/>

            </Grid>

        </GroupBox>
        <GroupBox x:Name="GBXEssais" Header="Essais" Margin="10,177,347,10">
            <Grid Height="230" Margin="10,0,14,0">
                <ListBox x:Name="LSBEssais" Margin="10,71,10,27" RenderTransformOrigin="0.5,0.5" SelectionChanged="LSBEssais_SelectionChanged">
                </ListBox>
                <Label x:Name="LBLEssais" Content="Essais restant :" HorizontalAlignment="Left" Margin="10,22,0,0" VerticalAlignment="Top" Width="104"/>
                <Label x:Name="LBLNbEssaisRestant" Content="NB" HorizontalAlignment="Left" Margin="111,23,0,0" VerticalAlignment="Top"/>
            </Grid>
        </GroupBox>
        <GroupBox Header="Historique des parties&#xD;&#xA;" Margin="292,24,19,76">
            <Grid>
                <ListBox x:Name="LSBHistorique" d:ItemsSource="{d:SampleData ItemCount=5}"/>
            </Grid>
        </GroupBox>
        <Button Content="Rejouer" HorizontalAlignment="Left" Margin="334,415,0,0" VerticalAlignment="Top" Height="39" Width="77" Click="Button_Click"/>
        <Button Content="Quitter" HorizontalAlignment="Left" Margin="485,415,0,0" VerticalAlignment="Top" Height="39" Width="77" Click="Button_Click_1"/>



    </Grid>
</Window>
